APP_NAME="Flashship Admin"
APP_ENV=production
APP_DEBUG=false
APP_KEY=           # php artisan key:generate
APP_URL=https://admin.flashship.vn

LOG_CHANNEL=daily
LOG_LEVEL=error    # Chỉ log lỗi, không log debug → nhanh hơn

# ── Database (cPanel MySQL) ─────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=flashship_admin
DB_USERNAME=flashship_user
DB_PASSWORD=YOUR_DB_PASSWORD

# ── Queue & Cache: dùng database, không cần Redis ──────────
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── Broadcast: tắt nếu không dùng Pusher ────────────────────
BROADCAST_CONNECTION=log

# ── Zalo ───────────────────────────────────────────────────
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_ACCESS_TOKEN=

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=

# ── Tắt Telescope/Debugbar trên production ─────────────────
TELESCOPE_ENABLED=false
